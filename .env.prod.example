# ── Production environment ──────────────────────────────────────────────────
# On your server: copy this file to ".env" and fill in real values.
#   cp .env.prod.example .env
#
# This single file feeds docker-compose.prod.yml. NEVER commit the real .env.

# A long random secret that signs login tokens.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=paste-a-64-character-random-string-here

# A strong database password (used by both Postgres and the backend).
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=paste-a-strong-password-here

# Your domain name (DNS must point to this server).
DOMAIN=teamflow.example.com

# Email for Let's Encrypt certificate notices.
EMAIL=you@example.com
