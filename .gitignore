# ── Secrets ───────────────────────────────────────────────────────────────
# NEVER commit .env — it contains your database password and secret key
.env
*.env

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# ── Docker ────────────────────────────────────────────────────────────────
# Docker creates these locally — no need to track them
docker-compose.override.yml

# ── Database ──────────────────────────────────────────────────────────────
*.sqlite3
*.db

# ── OS Files ──────────────────────────────────────────────────────────────
.DS_Store           # Mac metadata files
Thumbs.db           # Windows thumbnail cache
desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Uploaded files (stored in a Docker volume, not in git) ─────────────────
uploads/

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
logs/
